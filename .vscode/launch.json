{
  "version": "0.2.0",
  "configurations": [
    {"name":"Python Debugger: Current File","type":"debugpy","request":"launch","program":"${file}","console":"integratedTerminal"},
    {
      "name": "demo_track video (ReID)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/tools/demo_track.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/fast-reid:${env:PYTHONPATH}"
      },
      "args": [
        "video",
        "-f",
        "exps/example/coco/yolox_x.py",
        "--ckpt",
        "pretrained/yolox_x.pth",
        "--path",
        "videos/left.mp4",
        "--save_result",
        "--device",
        "gpu",
        "--reid",
        "--reid_config",
        "fast-reid/configs/Market1501/bagtricks_R50.yml",
        "--reid_weights",
        "fast-reid/pretrained/market_bot_R50.pth"
      ]
    },
    {
      "name": "debugger demo_track video (ReID)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/debugger/demo_track.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/fast-reid:${workspaceFolder}:${env:PYTHONPATH}"
      },
      "args": [
        "video",
        "-f",
        "exps/example/coco/yolox_x.py",
        "--ckpt",
        "pretrained/yolox_x.pth",
        "--path",
        "videos/left.mp4",
        "--save_result",
        "--device",
        "gpu",
        "--reid",
        "--reid_config",
        "fast-reid/configs/Market1501/bagtricks_R50.yml",
        "--reid_weights",
        "fast-reid/pretrained/market_bot_R50.pth",
        "--debug_costs",
        "--debug_frame_start",
        "1",
        "--debug_frame_end",
        "150"
      ]
    }
  ]
}
